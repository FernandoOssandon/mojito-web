# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://mojito:mojito_secret@localhost:5432/mojito_db"

# ── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ── MercadoPago (Pagos – principal) ──────────────────────────────────────────
# Obtener en https://www.mercadopago.cl/developers
MP_ACCESS_TOKEN=TEST-your-access-token-here
MP_PUBLIC_KEY=TEST-your-public-key-here
# URL que MercadoPago llama tras el pago (debe ser pública en producción)
MP_WEBHOOK_URL=https://yourdomain.com/api/payments/mp/webhook
MP_SUCCESS_URL=http://localhost:5173/checkout/success
MP_FAILURE_URL=http://localhost:5173/checkout/failure
MP_PENDING_URL=http://localhost:5173/checkout/pending

# ── Flow (Pagos – backup) ─────────────────────────────────────────────────────
# Obtener en https://www.flow.cl/app/web/developers.php
FLOW_API_KEY=your-flow-api-key
FLOW_SECRET_KEY=your-flow-secret-key
FLOW_API_URL=https://sandbox.flow.cl/api
# FLOW_API_URL=https://www.flow.cl/api  # producción

# ── Proveedor activo de pagos: "mercadopago" | "flow" ────────────────────────
PAYMENT_PROVIDER=mercadopago

# ── API Gateway – SII / eBoleta ───────────────────────────────────────────────
# Obtener en https://app.apigateway.cl
APIGATEWAY_TOKEN=your-apigateway-token-here
# RUT del emisor (sin puntos, con guión)  ej: 12345678-9
EMISOR_RUT=12345678-9
EMISOR_RAZON_SOCIAL=Nombre de la Terapeuta

# ── Cloudflare R2 (imágenes) ──────────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=mojito-assets
R2_PUBLIC_URL=https://assets.yourdomain.com

# ── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM=noreply@yourdomain.com
